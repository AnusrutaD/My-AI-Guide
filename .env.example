# ─────────────────────────────────────────────────────────────────────────────
# LLM API Keys
# ─────────────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=                # Optional when LLM_PROVIDER=ollama
GOOGLE_API_KEY=                   # Optional when LLM_PROVIDER=ollama
OPENAI_API_KEY=                   # Optional; used only for embeddings
LLM_PROVIDER=ollama               # ollama | cloud
OLLAMA_BASE_URL=http://localhost:11434
STRATEGIST_MODEL=qwen2.5:14b
QUESTION_SETTER_MODEL=llama3.1:8b
EVALUATOR_MODEL=qwen2.5-coder:14b

# ─────────────────────────────────────────────────────────────────────────────
# Search
# ─────────────────────────────────────────────────────────────────────────────
TAVILY_API_KEY=tvly-...

# ─────────────────────────────────────────────────────────────────────────────
# PostgreSQL (with pgvector extension enabled)
# ─────────────────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/ai_guide
DATABASE_URL_SYNC=postgresql+psycopg://postgres:password@localhost:5432/ai_guide

# ─────────────────────────────────────────────────────────────────────────────
# Twilio / WhatsApp
# ─────────────────────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ─────────────────────────────────────────────────────────────────────────────
# App
# ─────────────────────────────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
# Set to "sqlite" for local dev without Postgres (uses /tmp/ai_guide.db)
CHECKPOINTER_BACKEND=postgres
